  "keyFeatures": [
    "Async message publishing and consuming with Tokio",
    "Multiple broker backends: Redis, RabbitMQ, SurrealDB",
    "Configurable retry strategies for failed messages",
    "Connection pooling for high-throughput workloads",
    "Message scheduling with delay and scheduled_at support",
    "Message priority levels (1-5)",
    "Fairness queuing via disambiguators for multi-tenant workloads",
    "Auto-acknowledge and manual acknowledge/reject/cancel",
    "Concurrent message processing with configurable concurrency",
    "Type-safe message handling with generics and serde",
    "Management API for queue status monitoring (feature-gated)"
  ],
  "publicApiSurface": [
    "BroccoliQueue::builder(broker_url)",
